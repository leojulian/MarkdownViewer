<Window x:Class="MarkdownViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Markdown 查看器" Height="720" Width="1080"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 菜单栏 -->
        <Menu Grid.Row="0">
            <MenuItem Header="文件(_F)">
                <MenuItem Header="打开文件(_O)" Click="OpenFile_Click" InputGestureText="Ctrl+O"/>
                <MenuItem Header="打开文件夹(_D)" Click="OpenFolder_Click" InputGestureText="Ctrl+Shift+O"/>
                <Separator/>
                <MenuItem Header="重新加载(_R)" Click="Reload_Click" InputGestureText="F5"/>
                <Separator/>
                <MenuItem Header="退出(_X)" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="视图(_V)">
                <MenuItem Header="放大(_I)" Click="ZoomIn_Click" InputGestureText="Ctrl++"/>
                <MenuItem Header="缩小(_O)" Click="ZoomOut_Click" InputGestureText="Ctrl+-"/>
                <MenuItem Header="重置缩放(_0)" Click="ZoomReset_Click" InputGestureText="Ctrl+0"/>
                <Separator/>
                <MenuItem Header="切换深色模式(_D)" Click="ToggleDarkMode_Click" InputGestureText="Ctrl+D"/>
            </MenuItem>
            <MenuItem Header="帮助(_H)">
                <MenuItem Header="关于(_A)" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- 工具栏 -->
        <ToolBar Grid.Row="0" Margin="0,28,0,0">
            <Button Content="打开文件" Click="OpenFile_Click" Padding="8,3"/>
            <Button Content="打开文件夹" Click="OpenFolder_Click" Padding="8,3"/>
            <Button Content="重新加载" Click="Reload_Click" Padding="8,3"/>
            <Separator/>
            <Button Content="-" Click="ZoomOut_Click" Padding="8,3" FontSize="14"/>
            <TextBlock x:Name="ZoomText" Text="100%" VerticalAlignment="Center" Margin="5,0" MinWidth="45" TextAlignment="Center"/>
            <Button Content="+" Click="ZoomIn_Click" Padding="8,3" FontSize="14"/>
            <Separator/>
            <Button Content="深色模式" Click="ToggleDarkMode_Click" Padding="8,3"/>
        </ToolBar>

        <!-- 主区域: 左侧文件列表 + 右侧渲染区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="180"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧: 文件树 -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 标题栏 -->
                    <Border Grid.Row="0" Background="#f0f0f0" Padding="10,8" BorderBrush="#ddd" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📁 文档列表" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="FileCountText" Text="" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- TreeView -->
                    <TreeView x:Name="FileTreeView" Grid.Row="1" 
                              SelectedItemChanged="FileTreeView_SelectedItemChanged"
                              Background="White" BorderThickness="0" Padding="4,4">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="True"/>
                                <Setter Property="Foreground" Value="#333"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Padding" Value="2,1"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Grid>
            </Border>

            <!-- 分割线手柄 -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" 
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- 右侧: 渲染区域 + 搜索栏 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <wv2:WebView2 x:Name="webView" Grid.Row="0" />

                <!-- 搜索栏 -->
                <Border x:Name="SearchBar" Grid.Row="1" Background="#f5f5f5" 
                        BorderBrush="#ccc" BorderThickness="0,1,0,0"
                        Padding="8,6" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="14"/>
                        <TextBox x:Name="SearchBox" Grid.Column="1" VerticalAlignment="Center"
                                 KeyDown="SearchBox_KeyDown" TextChanged="SearchBox_TextChanged"
                                 Padding="4,3" FontSize="13"/>
                        <Button Grid.Column="2" Content="▲" Click="SearchPrev_Click" 
                                Padding="6,2" FontSize="10" ToolTip="上一个" Margin="4,0,0,0"/>
                        <Button Grid.Column="3" Content="▼" Click="SearchNext_Click" 
                                Padding="6,2" FontSize="10" ToolTip="下一个" Margin="2,0,0,0"/>
                        <TextBlock x:Name="SearchCountText" Grid.Column="4" Text="" 
                                   VerticalAlignment="Center" Margin="12,0,0,0" FontSize="12"
                                   Foreground="#666" MinWidth="60"/>
                        <Button Grid.Column="6" Content="✕" Click="SearchClose_Click"
                                Padding="6,2" FontSize="12" ToolTip="关闭搜索"
                                Background="Transparent" BorderThickness="0" Foreground="#999"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="就绪"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="FilePathText" Text=""/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
